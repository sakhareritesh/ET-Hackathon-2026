# AI Providers (at least one required)
GROQ_API_KEY=gsk_your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
AI_PROVIDER=groq

# Backend (FastAPI — full URL or port number)
AI_PORT=http://127.0.0.1:8000

# Supabase (Frontend — copy these into et-frontend/.env.local for Next.js)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Local Engine Mode (set to "false" to use API routes + AI backend)
NEXT_PUBLIC_USE_LOCAL_ENGINE=true

# Also in et-frontend/.env.local (Form 16, AI mentor proxy, life-events, etc.):
# AI_SERVICE_URL=http://127.0.0.1:8000
